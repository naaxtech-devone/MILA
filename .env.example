# Supabase — client (exposed to the browser via Vite)
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-key>"

# Supabase — server (JWT verification in server functions)
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# AI provider (any OpenAI-compatible chat-completions API)
AI_API_KEY="<api-key>"
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-5"
VITE_HCAPTCHA_SITEKEY="<hcaptcha-sitekey>"

# Dev admin account (see README "Auth & routes" for bootstrap steps)
ADMIN_EMAIL="<admin-email>"
ADMIN_PASSWORD="<admin-password>"
